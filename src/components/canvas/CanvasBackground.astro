---
// Canvas particle background — lifecycle-safe for Astro ClientRouter
---

<canvas
  id="hero-canvas"
  aria-hidden="true"
  style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"
></canvas>

<script>
  // Module-level variables persist across navigations (module scripts execute once)
  let rafId: number | null = null;
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  let particles: Array<{ x: number; y: number; vx: number; vy: number; r: number }> = [];
  let resizeObserver: ResizeObserver | null = null;

  // ---- Lifecycle: tear down before DOM swap ----

  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(rafId!);
    rafId = null;
    if (resizeObserver && canvas) {
      resizeObserver.unobserve(canvas);
    }
  });

  // ---- Lifecycle: initialize after every page load ----

  document.addEventListener('astro:page-load', () => {
    canvas = document.querySelector('#hero-canvas');
    if (!canvas) return; // Not on a hero page — exit silently

    // Respect user preference for reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      canvas.style.display = 'none';
      return;
    }

    ctx = canvas.getContext('2d');
    if (!ctx) return;

    setupResizeObserver();
    resizeCanvas();
    initParticles();
    startLoop();
  });

  // ---- Tab visibility: pause when hidden ----

  document.addEventListener('visibilitychange', () => {
    if (!canvas || !document.contains(canvas)) return;
    if (document.hidden) {
      cancelAnimationFrame(rafId!);
      rafId = null;
    } else {
      startLoop();
    }
  });

  // ---- Canvas sizing (HiDPI + DPR capped at 2x) ----

  function resizeCanvas() {
    if (!canvas || !ctx) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    // Must re-call scale after every canvas.width/height assignment (resets transform matrix)
    ctx.scale(dpr, dpr);
  }

  function setupResizeObserver() {
    if (!canvas) return;
    resizeObserver = new ResizeObserver(() => {
      cancelAnimationFrame(rafId!);
      rafId = null;
      resizeCanvas();
      initParticles();
      startLoop();
    });
    resizeObserver.observe(canvas);
  }

  // ---- Particles ----

  function initParticles() {
    if (!canvas) return;
    const w = canvas.getBoundingClientRect().width;
    const h = canvas.getBoundingClientRect().height;
    const count = Math.min(Math.max(Math.floor((w * h) / 8000), 20), 80);
    particles = Array.from({ length: count }, () => ({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      r: Math.random() * 1.2 + 0.4,
    }));
  }

  // ---- Animation loop ----

  function startLoop() {
    if (!canvas || !ctx) return;
    const w = canvas.getBoundingClientRect().width;
    const h = canvas.getBoundingClientRect().height;
    const linkRadius = 130;

    function tick() {
      if (!ctx) return;
      ctx.clearRect(0, 0, w, h);

      // Update and draw particles
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        // Toroidal wrapping — clean infinite drift effect
        if (p.x < 0) p.x = w;
        if (p.x > w) p.x = 0;
        if (p.y < 0) p.y = h;
        if (p.y > h) p.y = 0;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0, 255, 65, 0.6)';
        ctx.fill();
      }

      // Draw connection lines between nearby particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < linkRadius) {
            const opacity = (1 - dist / linkRadius) * 0.25;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(0, 255, 65, ${opacity})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      rafId = requestAnimationFrame(tick);
    }

    rafId = requestAnimationFrame(tick);
  }
</script>
