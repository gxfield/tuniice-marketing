---
// Card component with neo-brutalist styling
interface Props {
  accent?: 'primary' | 'secondary' | 'amber';
  muted?: boolean;
}

const { accent = 'primary', muted = false } = Astro.props;
---

<article class={`card card-${accent} ${muted ? 'card-muted' : ''}`}>
  <slot />
</article>

<style>
  .card {
    --mag-x: 0px;
    --mag-y: 0px;
    padding: var(--space-md);
    border: var(--border-width) solid var(--color-border);
    background: var(--color-bg-elevated);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    will-change: transform;
  }

  /* Accent variants */
  .card-primary {
    box-shadow: var(--shadow-offset-md) var(--shadow-offset-md) 0 var(--color-accent);
  }

  .card-secondary {
    box-shadow: var(--shadow-offset-md) var(--shadow-offset-md) 0 var(--color-accent-warm);
  }

  .card-amber {
    box-shadow: var(--shadow-offset-md) var(--shadow-offset-md) 0 var(--color-accent-amber);
  }

  /* Hover effect */
  .card:hover {
    transform: translate(calc(-2px + var(--mag-x)), calc(-2px + var(--mag-y)));
  }

  .card-primary:hover {
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 var(--color-accent);
  }

  .card-secondary:hover {
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 var(--color-accent-warm);
  }

  .card-amber:hover {
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 var(--color-accent-amber);
  }

  /* Muted state for coming-soon products */
  .card-muted {
    filter: grayscale(40%) opacity(75%);
    transition: filter 0.3s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .card-muted:hover {
    filter: grayscale(20%) opacity(90%);
  }

  /* Desktop padding increase */
  @media (min-width: 768px) {
    .card {
      padding: var(--space-lg);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // Gate: skip on touch devices or reduced-motion preference
    const ptrFine = window.matchMedia('(pointer: fine)').matches;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!ptrFine || reducedMotion) return;

    const cards = document.querySelectorAll('.card');

    cards.forEach((card) => {
      function onMove(e) {
        const rect = card.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (e.clientX - cx) * 0.15;
        const dy = (e.clientY - cy) * 0.15;
        card.style.setProperty('--mag-x', `${dx}px`);
        card.style.setProperty('--mag-y', `${dy}px`);
      }

      card.addEventListener('mouseenter', () => {
        card.addEventListener('mousemove', onMove);
      });

      card.addEventListener('mouseleave', () => {
        card.removeEventListener('mousemove', onMove);
        card.style.setProperty('--mag-x', '0px');
        card.style.setProperty('--mag-y', '0px');
      });
    });
  });
</script>
