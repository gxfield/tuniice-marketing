---
// ProductCard component - displays product information in a Card
import Card from './Card.astro';
import type { Product } from '../../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<Card accent={product.accent} muted={true}>
  <div class="product-card">
    <div class="product-image">
      <img src={product.image} alt={product.name} />
    </div>
    <div class="product-content">
      <span class={`product-category product-category-${product.accent}`}>
        {product.category.toUpperCase()}
      </span>
      <h3 class="product-name">{product.name}</h3>
      <p class="product-tagline">{product.tagline}</p>
      <p class="product-status">Coming Soon</p>
    </div>
  </div>
</Card>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .product-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .product-category {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--font-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: var(--border-width) solid currentColor;
    width: fit-content;
  }

  .product-category-primary {
    color: var(--color-accent);
  }

  .product-category-secondary {
    color: var(--color-accent-warm);
  }

  .product-category-amber {
    color: var(--color-accent-amber);
  }

  .product-name {
    font-family: var(--font-heading);
    font-size: var(--font-xl);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .product-tagline {
    font-family: var(--font-body);
    font-size: var(--font-md);
    color: var(--color-text-muted);
    margin: 0;
  }

  .product-status {
    font-family: var(--font-body);
    font-size: var(--font-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
    margin-top: var(--space-xs);
  }
</style>
