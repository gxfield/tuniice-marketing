---
// Connect section - Email and social links
import Button from '../ui/Button.astro';
---

<section class="connect" id="connect">
  <h2 class="section-heading">Get in Touch</h2>

  <div class="email-container" data-animate>
    <Button href="mailto:greg@tuniice.com" variant="primary" size="lg">
      Email Me
    </Button>
  </div>

  <div class="social-links" data-animate>
    <Button href="https://bandcamp.com/tuniice" variant="primary" size="md">
      Bandcamp
    </Button>
    <Button href="https://soundcloud.com/tuniice" variant="secondary" size="md">
      SoundCloud
    </Button>
  </div>
</section>

<style>
  .connect {
    padding: var(--space-xl) 0;
    text-align: left;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-2xl);
    font-weight: 900;
    margin-bottom: var(--space-lg);
  }

  .email-container {
    margin-bottom: var(--space-lg);
    display: flex;
    justify-content: flex-start;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .connect {
      padding: var(--space-xl) 0;
    }
  }
</style>
