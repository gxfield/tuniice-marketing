---
// Founder story and technical background section
import Avatar from '../ui/Avatar.astro';
---

<section class="narrative">
  <div class="avatar-container" data-animate>
    <Avatar size="lg" />
  </div>

  <div class="story-text" data-animate>
    <p>
      I'm Greg, a musician and software engineer who's spent years bridging the creative and technical worlds. tuniice isn't just a brand—it's the intersection of everything I've learned about making tools that feel as natural as playing an instrument.
    </p>
    <p>
      From iOS apps to embedded hardware, audio DSP to web platforms, my mission is to build products that remove friction between intention and creation. Whether it's a synthesizer, a productivity tool, or a MIDI controller, every project starts with one question: does this feel right?
    </p>
    <p>
      This site showcases that philosophy in action. Simple, direct, and built to last. No unnecessary complexity. Just tools and music that work the way they should.
    </p>
  </div>

  <div class="technical-background">
    <h2 class="section-heading">Technical Background</h2>
    <div class="skills-grid">
      <div class="skill-category" data-animate>
        <h3 class="category-title">Software</h3>
        <ul class="skill-list">
          <li>iOS Development</li>
          <li>Web Applications</li>
          <li>Audio DSP</li>
        </ul>
      </div>
      <div class="skill-category" data-animate>
        <h3 class="category-title">Hardware</h3>
        <ul class="skill-list">
          <li>Circuit Design</li>
          <li>MIDI Controllers</li>
          <li>Embedded Systems</li>
        </ul>
      </div>
      <div class="skill-category" data-animate>
        <h3 class="category-title">Audio</h3>
        <ul class="skill-list">
          <li>Music Production</li>
          <li>Sound Design</li>
          <li>Mixing & Mastering</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .narrative {
    padding: var(--space-2xl) var(--space-md);
    max-width: 800px;
    margin: 0 auto;
  }

  .avatar-container {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }

  .story-text {
    font-family: var(--font-body);
    font-size: var(--font-base);
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-2xl);
  }

  .story-text p {
    margin-bottom: var(--space-lg);
  }

  .story-text p:last-child {
    margin-bottom: 0;
  }

  .technical-background {
    margin-top: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-2xl);
    font-weight: 900;
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .narrative {
      padding: var(--space-2xl) var(--space-lg);
    }

    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .skill-category {
    border: var(--border-width) solid var(--color-border);
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: var(--font-lg);
    font-weight: 700;
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-list li {
    font-family: var(--font-body);
    font-size: var(--font-sm);
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .skill-list li:last-child {
    border-bottom: none;
  }
</style>
