---
// Founder story and technical background section
import Avatar from '../ui/Avatar.astro';
---

<section class="narrative">
  <div class="avatar-container" data-animate>
    <Avatar size="lg" />
  </div>

  <div class="story-text" data-animate>
    <p>
      tuniice is a convergence of two decades of electronic composition and fifteen years of software engineering.
    </p>
    <p>
      It is a project born from necessity—a maker’s workshop dedicated to tools that dissolve the barrier between the musician’s mind and the speaker cone.
    </p>
    <p>
      Here, code is treated with the same reverence as audio. The apps built here are not just utilities; they are instruments, refined by years of listening.
    </p>
    <p>
      Pure signal. Zero noise.
    </p>
  </div>

  <div class="technical-background">
    <h2 class="section-heading">Technical Background</h2>
    <div class="skills-grid">
      <div class="skill-category" data-animate>
        <h3 class="category-title">Software</h3>
        <ul class="skill-list">
          <li>iOS Development</li>
          <li>Web Applications</li>
          <li>Audio DSP</li>
        </ul>
      </div>
      <div class="skill-category" data-animate>
        <h3 class="category-title">Audio</h3>
        <ul class="skill-list">
          <li>Music Production</li>
          <li>Sound Design</li>
          <li>Mixing & Mastering</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .narrative {
    padding: var(--space-xl) 0;
    max-width: 900px;
    margin: 0;
  }

  .avatar-container {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-2xl);
  }

  .story-text {
    font-family: var(--font-body);
    font-size: var(--font-base);
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .story-text p {
    margin-bottom: var(--space-lg);
  }

  .story-text p:last-child {
    margin-bottom: 0;
  }

  .technical-background {
    margin-top: var(--space-2xl);
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--font-2xl);
    font-weight: 900;
    text-align: left;
    margin-bottom: var(--space-lg);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .narrative {
      padding: var(--space-xl) 0;
    }

    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .skill-category {
    border: var(--border-width) solid var(--color-border);
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
  }

  .category-title {
    font-family: var(--font-heading);
    font-size: var(--font-lg);
    font-weight: 700;
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-list li {
    font-family: var(--font-body);
    font-size: var(--font-sm);
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .skill-list li:last-child {
    border-bottom: none;
  }
</style>
