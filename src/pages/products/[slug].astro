---
// Product detail page - dynamic route
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotifyForm from '../../components/forms/NotifyForm.astro';
import { products } from '../../data/products';
import type { Product } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<BaseLayout title={product.name}>
  <div class="product-detail">
    <nav class="back-nav">
      <a href="/products" class="back-link">← Back to Products</a>
    </nav>

    <article class="product-content">
      <header class="product-header">
        <h1 class="product-name">{product.name}</h1>
        <div class="product-meta">
          <span class={`category-badge category-badge-${product.accent}`}>
            {product.category.toUpperCase()}
          </span>
          <span class="status-badge">Coming Soon</span>
        </div>
      </header>

      <div class="product-image">
        <img src={product.image} alt={product.name} />
      </div>

      <div class="product-description">
        <p>{product.description}</p>
      </div>

      <div class="divider"></div>

      <section class="notify-section">
        <h2 class="notify-heading">Get Notified</h2>
        <p class="notify-text">Be the first to know when {product.name} launches.</p>
        <NotifyForm />
      </section>
    </article>
  </div>
</BaseLayout>

<style>
  .product-detail {
    max-width: 700px;
    margin: 0 auto;
  }

  .back-nav {
    margin-bottom: var(--space-lg);
  }

  .back-link {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--font-md);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .product-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .product-header {
    text-align: center;
  }

  .product-name {
    font-family: var(--font-heading);
    font-size: var(--font-3xl);
    font-weight: 900;
    color: var(--color-text);
    margin: 0 0 var(--space-md) 0;
  }

  .product-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .category-badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--font-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: var(--border-width) solid currentColor;
  }

  .category-badge-primary {
    color: var(--color-accent);
  }

  .category-badge-secondary {
    color: var(--color-accent-warm);
  }

  .category-badge-amber {
    color: var(--color-accent-amber);
  }

  .status-badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--font-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .product-image {
    width: 100%;
    border: var(--border-width) solid var(--color-border);
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .product-description {
    text-align: center;
  }

  .product-description p {
    font-family: var(--font-body);
    font-size: var(--font-md);
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .divider {
    width: 100%;
    height: 0;
    border-top: var(--border-width) solid var(--color-border);
    margin: var(--space-lg) 0;
  }

  .notify-section {
    text-align: center;
  }

  .notify-heading {
    font-family: var(--font-heading);
    font-size: var(--font-xl);
    font-weight: 900;
    color: var(--color-text);
    margin: 0 0 var(--space-sm) 0;
  }

  .notify-text {
    font-family: var(--font-body);
    font-size: var(--font-md);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-lg) 0;
  }

  @media (min-width: 768px) {
    .product-name {
      font-size: var(--font-3xl);
    }
  }
</style>
