---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/animations.css';

const currentYear = new Date().getFullYear();
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || 'YOUR_FORM_ID';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="bluepriint — master clock and tempo control for live performance" />
    <title>bluepriint | tuniice</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=space-grotesk:700,900|space-mono:400,700"
    />
  </head>
  <body>
    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-inner">
          <h1 class="product-name" data-animate>bluepriint</h1>
          <p class="tagline" data-animate>Master clock and tempo control for live performance</p>
          <p class="description" data-animate>
            Tempo-locked arrangements, master clock sync, and deterministic cue control —
            engineered for the demands of live electronic performance.
          </p>
        </div>
      </section>

      <!-- Features -->
      <section class="features">
        <h2 class="section-label" data-animate>Capabilities</h2>
        <div class="features-grid">
          <div class="feature-card" data-animate>
            <h3>Master Clock</h3>
            <p>
              One authoritative tempo source. Sync all hardware and software to a single beat,
              eliminating drift across your entire rig.
            </p>
          </div>
          <div class="feature-card" data-animate>
            <h3>Arrangement Engine</h3>
            <p>
              Program tempo changes, time signature shifts, and cue points in advance.
              Execute complex structures without improvising under pressure.
            </p>
          </div>
          <div class="feature-card" data-animate>
            <h3>Live Control</h3>
            <p>
              Real-time adjustments that propagate instantly across connected devices.
              Nudge, jump, and transition with surgical precision mid-set.
            </p>
          </div>
          <div class="feature-card" data-animate>
            <h3>Session Export</h3>
            <p>
              Capture your live arrangement as a structured session file.
              Import directly into your DAW for post-performance production.
            </p>
          </div>
        </div>
      </section>

      <!-- CTA / Email signup -->
      <section class="cta">
        <div class="cta-inner">
          <h2 data-animate>Get notified when bluepriint launches</h2>
          <p class="cta-sub" data-animate>
            Early access and development updates. No noise, no marketing.
          </p>
          <form
            id="notify-form"
            class="notify-form"
            action={`https://formspree.io/f/${formspreeId}`}
            method="POST"
            data-animate
          >
            <input type="hidden" name="_subject" value="bluepriint Launch Notification Signup" />
            <div class="form-row">
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                required
                class="email-input"
                aria-label="Email address"
              />
              <button type="submit" class="submit-btn">Get Notified</button>
            </div>
            <p id="form-success" class="form-msg form-msg--success" hidden>
              You're on the list. We'll be in touch.
            </p>
            <p id="form-error" class="form-msg form-msg--error" hidden>
              Something went wrong. Try again or email us directly.
            </p>
          </form>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a href="https://tuniice.com" class="footer-link">tuniice.com</a>
        <span class="footer-copy">&copy; {currentYear} tuniice</span>
      </div>
    </footer>

    <script>
      // Scroll-triggered animations
      document.addEventListener('DOMContentLoaded', () => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );

        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
      });

      // Async form submission
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('notify-form') as HTMLFormElement | null;
        const successMsg = document.getElementById('form-success') as HTMLElement | null;
        const errorMsg = document.getElementById('form-error') as HTMLElement | null;

        if (!form || !successMsg || !errorMsg) return;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const data = new FormData(form);

          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: data,
              headers: { Accept: 'application/json' },
            });

            if (res.ok) {
              form.reset();
              successMsg.hidden = false;
              errorMsg.hidden = true;
            } else {
              errorMsg.hidden = false;
              successMsg.hidden = true;
            }
          } catch {
            errorMsg.hidden = false;
            successMsg.hidden = true;
          }
        });
      });
    </script>

    <style>
      /* Layout */
      body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main {
        flex: 1;
      }

      /* Hero */
      .hero {
        padding: var(--space-2xl) var(--space-md);
        padding-top: clamp(3rem, 10vw, 6rem);
        padding-bottom: clamp(3rem, 10vw, 6rem);
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-inner {
        max-width: 720px;
      }

      .product-name {
        font-size: clamp(3rem, 10vw, 6rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        color: var(--color-accent);
        margin-bottom: var(--space-md);
        line-height: 1;
      }

      .tagline {
        font-family: var(--font-heading);
        font-size: clamp(var(--font-lg), 3vw, var(--font-2xl));
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: var(--space-lg);
        line-height: 1.3;
      }

      .description {
        font-size: var(--font-base);
        color: var(--color-text-muted);
        max-width: 560px;
        line-height: 1.7;
      }

      /* Features */
      .features {
        padding: clamp(3rem, 8vw, 5rem) var(--space-md);
        max-width: 1400px;
        margin: 0 auto;
        border-top: var(--border-width) solid var(--color-border);
      }

      .section-label {
        font-size: var(--font-sm);
        font-family: var(--font-body);
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-text-muted);
        margin-bottom: var(--space-xl);
      }

      .features-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }

      @media (min-width: 640px) {
        .features-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      .feature-card {
        background: var(--color-bg-elevated);
        border: var(--border-width) solid var(--color-border);
        box-shadow: var(--shadow-offset-md) var(--shadow-offset-md) 0 var(--color-accent);
        padding: var(--space-xl);
      }

      .feature-card h3 {
        font-family: var(--font-heading);
        font-size: var(--font-md);
        font-weight: 900;
        color: var(--color-accent);
        margin-bottom: var(--space-sm);
        letter-spacing: -0.01em;
      }

      .feature-card p {
        font-size: var(--font-sm);
        color: var(--color-text-muted);
        line-height: 1.7;
      }

      /* CTA */
      .cta {
        padding: clamp(3rem, 8vw, 5rem) var(--space-md);
        border-top: var(--border-width) solid var(--color-border);
        border-bottom: var(--border-width) solid var(--color-border);
      }

      .cta-inner {
        max-width: 640px;
        margin: 0 auto;
        text-align: center;
      }

      .cta-inner h2 {
        font-size: clamp(var(--font-xl), 4vw, var(--font-2xl));
        font-weight: 900;
        letter-spacing: -0.02em;
        margin-bottom: var(--space-sm);
      }

      .cta-sub {
        color: var(--color-text-muted);
        font-size: var(--font-sm);
        margin-bottom: var(--space-xl);
      }

      .notify-form {
        width: 100%;
      }

      .form-row {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      @media (min-width: 520px) {
        .form-row {
          flex-direction: row;
        }
      }

      .email-input {
        flex: 1;
        padding: var(--space-sm) var(--space-md);
        background: var(--color-bg-elevated);
        border: var(--border-width) solid var(--color-border);
        color: var(--color-text);
        font-size: var(--font-base);
        outline: none;
        border-radius: var(--radius);
      }

      .email-input:focus {
        border-color: var(--color-accent);
        box-shadow: var(--shadow-offset-sm) var(--shadow-offset-sm) 0 var(--color-accent);
      }

      .submit-btn {
        padding: var(--space-sm) var(--space-xl);
        background: var(--color-accent);
        color: var(--color-bg);
        border: var(--border-width) solid var(--color-border);
        font-family: var(--font-heading);
        font-weight: 900;
        font-size: var(--font-base);
        letter-spacing: 0.02em;
        cursor: pointer;
        border-radius: var(--radius);
        box-shadow: var(--shadow-offset-md) var(--shadow-offset-md) 0 var(--color-border);
        transition: transform 0.1s ease, box-shadow 0.1s ease;
        white-space: nowrap;
      }

      .submit-btn:hover {
        transform: translate(-2px, -2px);
        box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 var(--color-border);
      }

      .submit-btn:active {
        transform: translate(0, 0);
        box-shadow: var(--shadow-offset-sm) var(--shadow-offset-sm) 0 var(--color-border);
      }

      .form-msg {
        margin-top: var(--space-md);
        font-size: var(--font-sm);
        text-align: center;
      }

      .form-msg--success {
        color: var(--color-accent);
      }

      .form-msg--error {
        color: var(--color-accent-warm);
      }

      /* Footer */
      .site-footer {
        padding: var(--space-lg) var(--space-md);
        border-top: var(--border-width) solid var(--color-accent);
      }

      .footer-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-md);
        flex-wrap: wrap;
      }

      .footer-link {
        color: var(--color-accent);
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: var(--font-sm);
        letter-spacing: 0.04em;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .footer-link:hover {
        color: var(--color-text);
      }

      .footer-copy {
        font-size: var(--font-sm);
        color: var(--color-text-muted);
      }
    </style>
  </body>
</html>
